{
  "name": "opencode-proxy",
  "version": "0.1.0",
  "description": "Anthropic-compatible proxy for OpenCode Go's OpenAI-compatible API.",
  "private": false,
  "type": "commonjs",
  "bin": {
    "opencode-proxy": "./index.js"
  },
  "scripts": {
    "start": "node index.js",
    "health": "node -e \"fetch('http://127.0.0.1:11434/health').then(r=>r.text()).then(console.log)\""
  },
  "engines": {
    "node": ">=18"
  },
  "keywords": [
    "opencode",
    "anthropic",
    "claude",
    "proxy",
    "openai-compatible"
  ]
}
